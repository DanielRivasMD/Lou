////////////////////////////////////////////////////////////////////////////////////////////////////

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        children
    }

   tab {
        pane stacked=true split_direction="horizontal" {
            pane name="explore" command="yazi" focus=true
            pane name="canvas"
            pane name="nu" command="nu"
        }
    }
}

